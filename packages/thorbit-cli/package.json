{
  "name": "thorbit-cli",
  "version": "0.2.0",
  "description": "Generated command-line client for every Thorbit tool",
  "license": "MIT",
  "homepage": "https://github.com/VilovietaSEO/thorbit-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VilovietaSEO/thorbit-sdk.git",
    "directory": "packages/thorbit-cli"
  },
  "bugs": {
    "url": "https://github.com/VilovietaSEO/thorbit-sdk/issues"
  },
  "type": "module",
  "sideEffects": false,
  "bin": {
    "thorbit": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node --input-type=module --eval \"import { chmodSync } from 'node:fs'; chmodSync('dist/index.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "thorbit-sdk": "0.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
